# Скопируйте в .env рядом с docker-compose.yml (Portainer подхватит через env_file).
EMAIL_SECRETS_DIR=./secrets
# CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=https://mail.inoxsigns.com
AUTH_ENABLED=true
AUTH_ALLOW_REGISTER=false
JWT_EXPIRES_IN=8h
APP_TIMEZONE=Europe/Moscow
MAIL_MAX_ATTACHMENT_SIZE=26214400

# Публичный IP для DNS A/SPF (на проде — env Portainer или /opt/email/secret/server_public_ip)
SERVER_PUBLIC_IP=YOUR.SERVER.IP
# Hostname MTA (на проде — env Portainer или /opt/email/secret/mail_hostname)
MAIL_HOSTNAME=mail.example.com

# MTA включён по умолчанию (Haraka в docker-compose.yml). Локально без Haraka: MTA_ENABLED=false
MTA_ENABLED=true
HARAKA_HOST=email_haraka
HARAKA_SUBMISSION_PORT=587

# Docker local override
POSTGRES_USER=mailuser
POSTGRES_DB=corp_mail
